# KOSHA 포털 계정
KOSHA_ID=your_id
KOSHA_PW=your_password

# common_data DB 연결 URL
# 로컬(SSH 터널): postgresql://common_admin:PASS@127.0.0.1:5435/common_data
# 서버(직접):     postgresql://common_admin:PASS@192.168.120.18:5432/common_data
COMMON_DATA_URL=postgresql://common_admin:PASS@127.0.0.1:5435/common_data

# 파일 저장 루트 경로 (비워두면 scraper/kosha_files/ 사용)
# 로컬: 비워두거나 NAS 마운트 경로 (예: Z:\kosha-files 또는 /mnt/nas/kosha-files)
# 서버: /nas/kosha-files
KOSHA_FILES_BASE=
