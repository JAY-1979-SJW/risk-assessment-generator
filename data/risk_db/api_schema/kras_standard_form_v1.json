{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kras_standard_form_v1.json",
  "title": "KRAS Standard Risk Assessment Form (본표)",
  "description": "위험성평가표 본표 (위험성평가실시) 표준 출력 구조 v1. 공문기반 16컬럼 서식 + KRAS 12컬럼 축약형 양쪽을 수용. 산안법 §36·시행규칙 §37·고용노동부고시 제2023-19호·건설업 활용가이드 준거.",
  "type": "object",
  "required": ["form_version", "header", "rows"],
  "additionalProperties": false,
  "properties": {
    "form_version": {
      "type": "string",
      "const": "kras-standard-v1",
      "description": "양식 버전 식별자"
    },
    "header": { "$ref": "#/$defs/FormHeader" },
    "scale_definition": {
      "$ref": "#/$defs/ScaleDefinition",
      "description": "위험성 추정 방식. 생략 시 3x3 곱셈식 기본."
    },
    "rows": {
      "type": "array",
      "minItems": 0,
      "description": "본표 row 배열. hazard 1건 = row 1행. 위험성 DESC 정렬.",
      "items": { "$ref": "#/$defs/AssessmentRow" }
    },
    "input_context": {
      "$ref": "#/$defs/InputContext",
      "description": "v2 API enrichment 입력 echo (equipment/location/conditions). 생략 가능."
    }
  },
  "$defs": {
    "FormHeader": {
      "type": "object",
      "required": ["assessment_type", "assessment_date"],
      "additionalProperties": false,
      "description": "본표 상단 메타. 회사/현장 정보는 사용자 제공 슬롯. 엔진은 비워둠.",
      "properties": {
        "company_name": { "type": "string", "description": "회사명" },
        "site_name":    { "type": "string", "description": "현장명/사업장명" },
        "industry":     { "type": "string", "description": "업종 (예: 건설업, 제조업)" },
        "representative": { "type": "string", "description": "대표자 성명" },
        "assessment_type": {
          "type": "string",
          "enum": ["최초평가", "정기평가", "수시평가", "상시평가"],
          "description": "산안법 시행규칙 §37 및 고시 §15 구분"
        },
        "assessment_date": {
          "type": "string",
          "description": "평가일자 (YYYY-MM-DD)",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "work_type": {
          "type": "string",
          "description": "KRAS 엔진 입력 work_type (본표의 공정명 기본값 원천)"
        }
      }
    },
    "ScaleDefinition": {
      "type": "object",
      "required": ["notation", "probability_levels", "severity_levels"],
      "additionalProperties": false,
      "properties": {
        "notation": { "type": "string", "enum": ["3x3"], "default": "3x3" },
        "probability_levels": {
          "type": "object",
          "required": ["1", "2", "3"],
          "additionalProperties": false,
          "properties": {
            "1": { "type": "string", "const": "하" },
            "2": { "type": "string", "const": "중" },
            "3": { "type": "string", "const": "상" }
          }
        },
        "severity_levels": {
          "type": "object",
          "required": ["1", "2", "3"],
          "additionalProperties": false,
          "properties": {
            "1": { "type": "string", "const": "소" },
            "2": { "type": "string", "const": "중" },
            "3": { "type": "string", "const": "대" }
          }
        },
        "risk_bands": {
          "type": "object",
          "description": "위험성(가능성×중대성) 범위별 등급",
          "properties": {
            "low":      { "type": "array", "items": { "type": "integer" }, "default": [1, 2] },
            "medium":   { "type": "array", "items": { "type": "integer" }, "default": [3, 4] },
            "high":     { "type": "array", "items": { "type": "integer" }, "default": [6] },
            "critical": { "type": "array", "items": { "type": "integer" }, "default": [9] }
          }
        }
      }
    },
    "AssessmentRow": {
      "type": "object",
      "required": [
        "no",
        "process",
        "hazard",
        "probability",
        "severity",
        "risk_level",
        "control_measures",
        "risk_band"
      ],
      "additionalProperties": false,
      "properties": {
        "no": {
          "type": "integer",
          "minimum": 1,
          "description": "행 번호 (1부터)"
        },
        "process": {
          "type": "string",
          "minLength": 1,
          "description": "공정명 (작업 대분류)"
        },
        "sub_work": {
          "type": ["string", "null"],
          "description": "세부작업명 (건설업 권장). 미정 시 null."
        },
        "hazard_category_major": {
          "type": ["string", "null"],
          "description": "위험분류 대분류 (추락·감전·화재 등). 미정 시 null."
        },
        "hazard_category_minor": {
          "type": ["string", "null"],
          "description": "위험분류 중분류. 미정 시 null."
        },
        "hazard": {
          "type": "string",
          "minLength": 1,
          "description": "유해위험요인 — 상황·원인·예상결과 서술"
        },
        "legal_basis": {
          "type": ["string", "null"],
          "description": "관련근거 (법적기준). 산안기준규칙 조문 등. 미정 시 null."
        },
        "current_measures": {
          "type": ["string", "null"],
          "description": "현재의 안전보건조치. 현장에 이미 적용 중. 입력 전 null."
        },
        "risk_scale": {
          "type": "string",
          "enum": ["3x3"],
          "default": "3x3",
          "description": "평가척도"
        },
        "probability": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "description": "가능성(빈도) 1~3"
        },
        "severity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "description": "중대성(강도) 1~3"
        },
        "risk_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9,
          "description": "위험성 = probability × severity"
        },
        "risk_band": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "위험성 등급 (scale_definition.risk_bands 기반)"
        },
        "control_measures": {
          "type": "array",
          "minItems": 1,
          "maxItems": 7,
          "items": { "type": "string", "minLength": 1 },
          "description": "위험성 감소대책 목록"
        },
        "residual_probability": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 3,
          "description": "감소대책 이행 후 가능성. 미추정 시 null."
        },
        "residual_severity": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 3,
          "description": "감소대책 이행 후 중대성. 미추정 시 null."
        },
        "residual_risk_level": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 9,
          "description": "개선후 위험성 = residual_probability × residual_severity. 둘 다 존재 시만."
        },
        "residual_risk_band": {
          "type": ["string", "null"],
          "enum": ["low", "medium", "high", "critical", null],
          "description": "개선후 위험성 등급"
        },
        "target_date": {
          "type": ["string", "null"],
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "개선 예정일 (YYYY-MM-DD). 미정 시 null."
        },
        "completion_date": {
          "type": ["string", "null"],
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "완료일 (YYYY-MM-DD). 미완료 시 null."
        },
        "responsible_person": {
          "type": ["string", "null"],
          "description": "담당자 성명·직책. 미지정 시 null."
        },
        "references_detail": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "description": "근거 상세 (엔진 내부 용도). 출력 표에는 표시 안 함.",
          "properties": {
            "law_ids":       { "type": "array", "items": { "type": "integer" } },
            "moel_expc_ids": { "type": "array", "items": { "type": "integer" } },
            "kosha_ids":     { "type": "array", "items": { "type": "integer" } }
          }
        }
      }
    },
    "InputContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "equipment":  { "type": "array", "items": { "type": "string" } },
        "location":   { "type": "array", "items": { "type": "string" } },
        "conditions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
